{
  "name": "anvyll",
  "version": "0.1.0",
  "description": "Windows-native AI prompt optimization studio with a system-wide hotkey overlay.",
  "author": "Anvyll",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELEC -c green,cyan \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "npm run build:vite && npm run build:main",
    "start": "electron .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "clean": "rimraf dist dist-renderer"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "koffi": "^3.0.2",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.11.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.8",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.anvyll.app",
    "productName": "Anvyll",
    "files": [
      "dist/**/*",
      "dist-renderer/**/*",
      "packs/**/*",
      "prompting-guides/**/*",
      "scripts/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
